{% doc %}
  Renders a compact thumbnail for a series gallery item.

  @param {product} series_product - The product to render as a thumbnail
  @param {product} current_product - The currently viewed product (for highlighting)

  @example
  {% render 'series-thumbnail', series_product: p, current_product: product %}
{% enddoc %}

{%- liquid
  assign is_current = false
  if series_product.id == current_product.id
    assign is_current = true
  endif
  assign issue_num = series_product.metafields.kings.issue_number.value
-%}

<a
  href="{{ series_product.url }}"
  class="series-thumb{% if is_current %} series-thumb--active{% endif %}"
  {% if is_current %}aria-current="page"{% endif %}
  title="{{ series_product.title | escape }}"
>
  <div class="series-thumb__image">
    {% if series_product.featured_image %}
      {{ series_product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: series_product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </div>
  {% if issue_num %}
    <span class="series-thumb__issue">#{{ issue_num }}</span>
  {% endif %}
  {% if series_product.metafields.kings.key_issue.value %}
    <span class="series-thumb__key" aria-label="{{ 'collection.key_issue' | t }}">
      <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 1l2.5 4.5L16 6.5l-4 3.5 1 5.5L8 13l-5 2.5 1-5.5L0 6.5l5.5-1L8 1z" fill="currentColor"/>
      </svg>
    </span>
  {% endif %}
</a>

{% stylesheet %}
  .series-thumb {
    flex: 1 0 50px;
    max-width: 80px;
    display: block;
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.15s ease, transform 0.15s ease;
    text-decoration: none;
  }
  .series-thumb__image { aspect-ratio: 2 / 3; background: #f7f7f8; filter: grayscale(100%); opacity: 0.5; transition: filter 0.2s ease, opacity 0.2s ease; }
  .series-thumb:hover { border-color: #e2e2e4; transform: translateY(-2px); }
  .series-thumb:hover .series-thumb__image { filter: grayscale(0%); opacity: 0.8; }
  .series-thumb--active { border-color: #e53e3e; box-shadow: 0 0 0 1px #e53e3e; }
  .series-thumb--active .series-thumb__image { filter: grayscale(0%); opacity: 1; }
  .series-thumb--active:hover { border-color: #e53e3e; }
  .series-thumb__image img { width: 100%; height: 100%; object-fit: cover; }
  .series-thumb__issue {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2px 0;
    text-align: center;
    font-size: 0.6rem;
    font-weight: 700;
    color: #fff;
    background: rgba(0,0,0,0.6);
    line-height: 1.2;
  }
  .series-thumb__key {
    position: absolute;
    top: 3px;
    right: 3px;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fef3c7;
    color: #b45309;
    border-radius: 50%;
  }
{% endstylesheet %}
