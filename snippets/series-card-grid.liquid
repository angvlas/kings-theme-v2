{% doc %}
  Renders a series collection as a grid card with cover image on top
  and title + metadata below. Mirrors the data attributes of
  series-card-list so the same filter/search JS works on both views.

  @param {collection} series_collection - The series collection to render.

  @example
  {% render 'series-card-grid', series_collection: c %}
{% enddoc %}

{%- liquid
  assign first_product = series_collection.products.first
  assign cover = series_collection.image
  if cover == blank
    assign cover = first_product.featured_image
  endif

  assign series_start = series_collection.metafields.kings.series_start
  assign series_end = series_collection.metafields.kings.series_end

  assign year_range = ''
  if series_start != blank and series_end != blank
    assign year_range = series_start | append: ' – ' | append: series_end
  elsif series_start != blank
    assign year_range = 'Started ' | append: series_start
  elsif series_end != blank
    assign year_range = 'Ended ' | append: series_end
  endif

  assign issue_count = series_collection.metafields.kings.total_issues
  if issue_count == blank
    assign issue_count = series_collection.products_count
  endif

  assign brand = series_collection.metafields.kings.brand
  if brand == blank
    assign brand = first_product.vendor
  endif
-%}

<a href="{{ series_collection.url }}" class="scg"
  data-series-handle="{{ series_collection.handle }}"
  data-series-title="{{ series_collection.title | downcase | escape }}"
  data-series-start="{{ series_start }}"
  data-series-brand="{{ brand | escape }}">
  <div class="scg__image">
    {% if cover %}
      {{ cover | image_url: width: 400 | image_tag: loading: 'lazy', alt: series_collection.title }}
    {% else %}
      {{ 'collection-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="scg__body">
    <p class="scg__title">{{ series_collection.title | escape }}</p>

    {% if brand != blank %}
      <p class="scg__meta scg__brand">{{ brand | escape }}</p>
    {% endif %}

    <div class="scg__footer">
      {% if year_range != blank %}
        <span class="scg__meta">{{ year_range }}</span>
      {% endif %}

      {% if issue_count and issue_count > 0 %}
        <span class="scg__count">
          {{ issue_count }} {% if issue_count == 1 %}issue{% else %}issues{% endif %}
        </span>
      {% endif %}
    </div>
  </div>
</a>

{% stylesheet %}
  .scg {
    display: flex;
    flex-direction: column;
    background-color: var(--color-card-background, #fff);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .scg[hidden] {
    display: none;
  }

  .scg:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 750px) {
    .scg {
      border-radius: 12px;
    }
  }

  .scg__image {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #fafafa;
  }

  @media (min-width: 750px) {
    .scg__image {
      padding: 16px;
    }
  }

  .scg__image img,
  .scg__image svg {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .scg:hover .scg__image img {
    transform: scale(1.05);
  }

  .scg__body {
    padding: 10px 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  @media (min-width: 750px) {
    .scg__body {
      padding: 12px 14px 16px;
    }
  }

  .scg__title {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 4px;
    overflow-wrap: break-word;
    word-break: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .scg__title {
      font-size: 0.95rem;
    }
  }

  .scg__meta {
    font-size: 0.75rem;
    color: #718096;
    margin: 0;
  }

  .scg__brand {
    font-weight: 600;
    color: #4a5568;
  }

  .scg__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 6px;
    flex-wrap: wrap;
  }

  .scg__count {
    font-size: 0.72rem;
    font-weight: 600;
    color: #9b9ba0;
  }
{% endstylesheet %}
