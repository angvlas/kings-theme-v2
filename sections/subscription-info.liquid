<div class="sub-info">
  <div class="sub-info__grid">
    <div class="sub-info__main">
      <div class="sub-info__faq">
        <h2 class="sub-info__title">{{ section.settings.faq_heading }}</h2>

        {% if page.metafields.pages.faq != blank %}
          {% for faq in page.metafields.pages.faq.value %}
            {% liquid
              assign faq_question = faq.question.value | default: faq.questions.value
              assign faq_answer = faq.answer.value | default: faq.answers.value
            %}
            <details class="sub-info__faq-item">
              <summary class="sub-info__faq-question">
                <span>{{ faq_question }}</span>
                <svg class="sub-info__faq-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>
              <div class="sub-info__faq-answer">
                {{ faq_answer }}
              </div>
            </details>
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <details class="sub-info__faq-item" {{ block.shopify_attributes }}>
                <summary class="sub-info__faq-question">
                  <span>{{ block.settings.question }}</span>
                  <svg class="sub-info__faq-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <div class="sub-info__faq-answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="sub-info__sidebar">
      {% if section.settings.form_heading != blank %}
        <h2 class="sub-info__title">{{ section.settings.form_heading }}</h2>
      {% endif %}
      {% if section.settings.form_intro != blank %}
        <p class="sub-info__form-intro">{{ section.settings.form_intro }}</p>
      {% endif %}
      <div class="sub-info__form-wrapper">
        {% form 'contact', class: 'sub-info__form' %}
          {% if form.posted_successfully? %}
            <div class="sub-info__success">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="9" stroke="#38a169" stroke-width="1.5"/>
                <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#38a169" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p>{{ section.settings.success_message }}</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="sub-info__errors">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          {% if section.settings.form_tag != blank %}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.form_tag }}">
          {% endif %}
          {% if section.settings.form_subject != blank %}
            <input type="hidden" name="contact[subject]" value="{{ section.settings.form_subject }}">
          {% endif %}

          <div class="sub-info__field">
            <label for="sub-info-name" class="sub-info__label">
              {{ 'sections.contact_form.field_name' | t }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="sub-info-name"
              name="contact[name]"
              class="sub-info__input"
              placeholder="{{ 'sections.contact_form.field_name_placeholder' | t }}"
              required
              autocomplete="name"
            >
          </div>

          <div class="sub-info__field">
            <label for="sub-info-email" class="sub-info__label">
              {{ 'sections.contact_form.field_email' | t }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="sub-info-email"
              name="contact[email]"
              class="sub-info__input"
              required
              autocomplete="email"
            >
          </div>

          <div class="sub-info__field">
            <label for="sub-info-phone" class="sub-info__label">
              {{ 'sections.contact_form.field_phone' | t }}
            </label>
            <input
              type="tel"
              id="sub-info-phone"
              name="contact[phone]"
              class="sub-info__input"
              autocomplete="tel"
            >
          </div>

          <div class="sub-info__field">
            <label for="sub-info-message" class="sub-info__label">
              {{ 'sections.contact_form.field_message' | t }} <span aria-hidden="true">*</span>
            </label>
            <textarea
              id="sub-info-message"
              name="contact[body]"
              class="sub-info__textarea"
              rows="5"
              required
            ></textarea>
          </div>

          <button type="submit" class="sub-info__submit">
            {{ section.settings.submit_label }}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .sub-info {
    padding: 32px 0 48px;
  }

  @media (min-width: 750px) {
    .sub-info {
      padding: 48px 0 64px;
    }
  }

  .sub-info__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 990px) {
    .sub-info__grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .sub-info__title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 10px;
    position: relative;
  }

  .sub-info__title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 40px;
    height: 2px;
    background-color: #f4b400;
    border-radius: 2px;
  }

  @media (min-width: 750px) {
    .sub-info__title {
      font-size: 1.6rem;
      margin-bottom: 20px;
    }
  }

  .sub-info__faq {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sub-info__faq-item {
    background-color: #fff;
    border: 1px solid #e2e2e4;
    border-radius: 12px;
    overflow: hidden;
  }

  .sub-info__faq-item[open] {
    background-color: #fdfdfd;
  }

  .sub-info__faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
    transition: background-color 0.15s ease;
  }

  .sub-info__faq-question::-webkit-details-marker {
    display: none;
  }

  .sub-info__faq-question:hover {
    background-color: #f7f7f8;
  }

  .sub-info__faq-icon {
    flex-shrink: 0;
    color: #9b9ba0;
    transition: transform 0.2s ease;
  }

  details[open] .sub-info__faq-icon {
    transform: rotate(180deg);
  }

  .sub-info__faq-answer {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    padding: 4px 20px 20px;
  }

  .sub-info__form-wrapper {
    background: transparent;
    padding: 0;
  }

  .sub-info__form-intro {
    font-size: 0.9rem;
    color: #718096;
    margin: -8px 0 16px;
    line-height: 1.5;
  }

  .sub-info__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sub-info__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sub-info__label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
  }

  .sub-info__label span {
    color: #e53e3e;
  }

  .sub-info__input,
  .sub-info__textarea {
    padding: 10px 12px;
    border: 1px solid #e2e2e4;
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    color: var(--color-foreground, #333);
    background-color: #fff;
    transition: border-color 0.15s ease;
  }

  .sub-info__input:focus,
  .sub-info__textarea:focus {
    outline: none;
    border-color: var(--color-foreground, #333);
  }

  .sub-info__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .sub-info__submit {
    padding: 12px 28px;
    background-color: #f4b400;
    color: #1a1a1a;
    border: none;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    font-family: inherit;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 2px 6px rgba(244, 180, 0, 0.35);
  }

  .sub-info__submit:hover {
    background-color: #e0a200;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(244, 180, 0, 0.45);
  }

  .sub-info__success {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px;
    background-color: #f0fff4;
    border: 1px solid #c6f6d5;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #38a169;
    font-weight: 500;
  }

  .sub-info__errors {
    padding: 12px;
    background-color: #fff5f5;
    border: 1px solid #fed7d7;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #e53e3e;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.subscription_info.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.subscription_info.faq_header"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "t:labels.heading",
      "default": "FAQs"
    },
    {
      "type": "header",
      "content": "t:sections.subscription_info.form_header"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "t:labels.heading",
      "default": "Need help?"
    },
    {
      "type": "text",
      "id": "form_intro",
      "label": "t:labels.intro"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "t:labels.button_label",
      "default": "Send"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "t:labels.success_message",
      "default": "Thanks! We'll be in touch soon."
    },
    {
      "type": "text",
      "id": "form_subject",
      "label": "t:labels.form_subject",
      "default": "Subscription enquiry"
    },
    {
      "type": "text",
      "id": "form_tag",
      "label": "t:labels.form_tag",
      "default": "subscription"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "t:sections.faq_accordion.item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:labels.question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:labels.answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.subscription_info.name"
    }
  ]
}
{% endschema %}
