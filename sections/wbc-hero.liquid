<div class="wbc-hero">
  <h1 class="wbc-hero__title">{{ section.settings.heading }}</h1>
  {% if section.settings.subheading != blank %}
    <p class="wbc-hero__subtitle">{{ section.settings.subheading }}</p>
  {% endif %}
  {% if section.settings.intro != blank %}
    <div class="wbc-hero__intro">
      {{ section.settings.intro }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .wbc-hero {
    text-align: center;
    padding: 24px 0 16px;
  }

  @media (min-width: 750px) {
    .wbc-hero {
      padding: 32px 0 24px;
    }
  }

  .wbc-hero__title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  @media (min-width: 750px) {
    .wbc-hero__title {
      font-size: 2.4rem;
    }
  }

  .wbc-hero__subtitle {
    font-size: 0.95rem;
    color: #718096;
    max-width: 50ch;
    margin: 0 auto;
    line-height: 1.5;
  }

  .wbc-hero__intro {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.7;
    max-width: 70ch;
    margin: 16px auto 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.we_buy.hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "We buy collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Interested in selling your comic collection? We'd love to hear from you."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:labels.intro"
    }
  ],
  "presets": [
    {
      "name": "t:sections.we_buy.hero"
    }
  ]
}
{% endschema %}
