      "min": 4,
      "max": 50,
      "step": 2,
      "default": 24
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:labels.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:labels.columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:labels.filtering"
    },
    {
      "type": "checkbox",
      "id": "enable_filters",
      "label": "t:labels.enable_filters",
      "default": true
    },
  ]
}
{% endschema %}
