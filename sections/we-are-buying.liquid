<div class="wbc-buying">
  <h2 class="wbc-buying__title">{{ section.settings.heading }}</h2>
  {% if section.blocks.size > 0 %}
    <div class="wbc-buying__list">
      {% for block in section.blocks %}
        <span class="wbc-buying__tag" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .wbc-buying {
    padding: 8px 0;
  }

  @media (min-width: 750px) {
    .wbc-buying {
      padding: 12px 0;
    }
  }

  .wbc-buying__title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  @media (min-width: 750px) {
    .wbc-buying__title {
      font-size: 1.4rem;
      margin-bottom: 20px;
    }
  }

  .wbc-buying__list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .wbc-buying__tag {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    background-color: #f7f7f8;
    border: 1px solid #e2e2e4;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.we_buy.buying_section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "We are currently buying"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.we_buy.buying_item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:labels.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.we_buy.buying_section",
      "blocks": [
        { "type": "item", "settings": { "label": "Silver Age comics" } },
        { "type": "item", "settings": { "label": "Key issues" } },
        { "type": "item", "settings": { "label": "Pokemon" } },
        { "type": "item", "settings": { "label": "Manga" } },
        { "type": "item", "settings": { "label": "Golden Age comics" } }
      ]
    }
  ]
}
{% endschema %}
