<div class="wbc-page">
  <div class="wbc-grid">
    <div class="wbc-main">
      <div class="wbc-faq" data-wbc-faq>
        <h2 class="wbc-section-title">{{ 'pages.we_buy.faq_title' | t }}</h2>

        {% if page.metafields.pages.faq != blank %}
          {% for faq in page.metafields.pages.faq.value %}
            {% liquid
              assign faq_question = faq.question.value | default: faq.questions.value
              assign faq_answer = faq.answer.value | default: faq.answers.value
            %}
            <details class="wbc-faq__item">
              <summary class="wbc-faq__question">
                <span>{{ faq_question }}</span>
                <svg class="wbc-faq__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>
              <div class="wbc-faq__answer">
                {{ faq_answer }}
              </div>
            </details>
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <details class="wbc-faq__item" {{ block.shopify_attributes }}>
                <summary class="wbc-faq__question">
                  <span>{{ block.settings.question }}</span>
                  <svg class="wbc-faq__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <div class="wbc-faq__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="wbc-sidebar">
      <h2 class="wbc-section-title">{{ 'pages.we_buy.form_title' | t }}</h2>
      <p class="wbc-form-intro">{{ 'pages.we_buy.form_intro' | t }}</p>
      <div class="wbc-form-wrapper">
        {% form 'contact', class: 'wbc-form' %}
          {% if form.posted_successfully? %}
            <div class="wbc-form__success">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="9" stroke="#38a169" stroke-width="1.5"/>
                <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#38a169" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p>{{ 'pages.we_buy.form_success' | t }}</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="wbc-form__errors">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <input type="hidden" name="contact[tags]" value="we-buy-collections">
          <input type="hidden" name="contact[subject]" value="{{ 'pages.we_buy.form_subject' | t }}">

          <div class="wbc-form__field">
            <label for="wbc-name" class="wbc-form__label">{{ 'pages.we_buy.field_name' | t }} <span aria-hidden="true">*</span></label>
            <input
              type="text"
              id="wbc-name"
              name="contact[name]"
              class="wbc-form__input"
              required
              autocomplete="name"
            >
          </div>

          <div class="wbc-form__field">
            <label for="wbc-email" class="wbc-form__label">{{ 'pages.we_buy.field_email' | t }} <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="wbc-email"
              name="contact[email]"
              class="wbc-form__input"
              required
              autocomplete="email"
            >
          </div>

          <div class="wbc-form__field">
            <label for="wbc-phone" class="wbc-form__label">{{ 'pages.we_buy.field_phone' | t }}</label>
            <input
              type="tel"
              id="wbc-phone"
              name="contact[phone]"
              class="wbc-form__input"
              autocomplete="tel"
            >
          </div>

          <div class="wbc-form__field">
            <label for="wbc-collection-type" class="wbc-form__label">{{ 'pages.we_buy.field_collection_type' | t }} <span aria-hidden="true">*</span></label>
            <select id="wbc-collection-type" name="contact[collection_type]" class="wbc-form__select" required>
              <option value="" disabled selected>{{ 'pages.we_buy.field_collection_type_placeholder' | t }}</option>
              <option value="Comics">{{ 'pages.we_buy.type_comics' | t }}</option>
              <option value="Graphic Novels">{{ 'pages.we_buy.type_graphic_novels' | t }}</option>
              <option value="Toys">{{ 'pages.we_buy.type_toys' | t }}</option>
              <option value="Trading Cards">{{ 'pages.we_buy.type_trading_cards' | t }}</option>
              <option value="Deceased Estates">{{ 'pages.we_buy.type_deceased_estates' | t }}</option>
              <option value="Large Collections">{{ 'pages.we_buy.type_large_collections' | t }}</option>
            </select>
          </div>

          <div class="wbc-form__field">
            <label for="wbc-description" class="wbc-form__label">{{ 'pages.we_buy.field_description' | t }} <span aria-hidden="true">*</span></label>
            <textarea
              id="wbc-description"
              name="contact[body]"
              class="wbc-form__textarea"
              rows="5"
              required
              placeholder="{{ 'pages.we_buy.field_description_placeholder' | t }}"
            ></textarea>
          </div>

          <button type="submit" class="wbc-form__submit">
            {{ 'pages.we_buy.form_submit' | t }}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .wbc-page {
    padding: 32px 0 60px;
  }

  @media (min-width: 750px) {
    .wbc-page {
      padding: 48px 0 80px;
    }
  }

  .wbc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 990px) {
    .wbc-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .wbc-section-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 10px;
    position: relative;
  }

  .wbc-section-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 40px;
    height: 2px;
    background-color: #f4b400;
    border-radius: 2px;
  }

  @media (min-width: 750px) {
    .wbc-section-title {
      font-size: 1.4rem;
      margin-bottom: 20px;
    }
  }

  .wbc-faq {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .wbc-faq__item {
    background-color: #fff;
    border: 1px solid #e2e2e4;
    border-radius: 12px;
    overflow: hidden;
  }

  .wbc-faq__item[open] {
    background-color: #fdfdfd;
  }

  .wbc-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
    transition: background-color 0.15s ease;
  }

  .wbc-faq__question::-webkit-details-marker {
    display: none;
  }

  .wbc-faq__question:hover {
    background-color: #f7f7f8;
  }

  .wbc-faq__icon {
    flex-shrink: 0;
    color: #9b9ba0;
    transition: transform 0.2s ease;
  }

  details[open] .wbc-faq__icon {
    transform: rotate(180deg);
  }

  .wbc-faq__answer {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    padding: 4px 20px 20px;
  }

  .wbc-form-wrapper {
    background: transparent;
    padding: 0;
  }

  .wbc-form-intro {
    font-size: 0.9rem;
    color: #718096;
    margin: -8px 0 16px;
    line-height: 1.5;
  }

  .wbc-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .wbc-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .wbc-form__label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
  }

  .wbc-form__label span {
    color: #e53e3e;
  }

  .wbc-form__input,
  .wbc-form__select,
  .wbc-form__textarea {
    padding: 10px 12px;
    border: 1px solid #e2e2e4;
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    color: var(--color-foreground, #333);
    background-color: #fff;
    transition: border-color 0.15s ease;
  }

  .wbc-form__input:focus,
  .wbc-form__select:focus,
  .wbc-form__textarea:focus {
    outline: none;
    border-color: var(--color-foreground, #333);
  }

  .wbc-form__select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 4.5L6 7.5L9 4.5' stroke='%239b9ba0' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 32px;
  }

  .wbc-form__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .wbc-form__submit {
    padding: 12px 28px;
    background-color: #f4b400;
    color: #1a1a1a;
    border: none;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    font-family: inherit;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 2px 6px rgba(244, 180, 0, 0.35);
  }

  .wbc-form__submit:hover {
    background-color: #e0a200;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(244, 180, 0, 0.45);
  }

  .wbc-form__success {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px;
    background-color: #f0fff4;
    border: 1px solid #c6f6d5;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #38a169;
    font-weight: 500;
  }

  .wbc-form__errors {
    padding: 12px;
    background-color: #fff5f5;
    border: 1px solid #fed7d7;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #e53e3e;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.we_buy.name",
  "settings": [],
  "blocks": [
    {
      "type": "faq",
      "name": "t:sections.we_buy.faq_item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:labels.question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:labels.answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.we_buy.name"
    }
  ]
}
{% endschema %}
