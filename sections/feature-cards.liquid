{% if section.blocks.size > 0 %}
  <div class="feature-cards">
    {% if section.settings.heading != blank %}
      <h2 class="feature-cards__title">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="feature-cards__grid">
      {% for block in section.blocks %}
        <div class="feature-cards__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div
              class="feature-cards__icon"
              style="--icon-bg: {{ block.settings.icon_color }}; --icon-color: {{ block.settings.icon_text_color }}"
            >
              <i class="{{ block.settings.icon }}" aria-hidden="true"></i>
            </div>
          {% endif %}
          <h3 class="feature-cards__card-title">{{ block.settings.title }}</h3>
          {% if block.settings.description != blank %}
            <p class="feature-cards__card-desc">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .feature-cards {
    padding: 16px 0;
  }

  @media (min-width: 750px) {
    .feature-cards {
      padding: 24px 0;
    }
  }

  .feature-cards__title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  @media (min-width: 750px) {
    .feature-cards__title {
      font-size: 1.4rem;
      margin-bottom: 24px;
    }
  }

  .feature-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 550px) {
    .feature-cards__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .feature-cards__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  .feature-cards__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 20px;
    background-color: #f7f7f8;
    border-radius: 12px;
    gap: 10px;
  }

  @media (min-width: 750px) {
    .feature-cards__card {
      padding: 32px 24px;
      gap: 12px;
    }
  }

  .feature-cards__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background-color: var(--icon-bg, #e8f5e9);
    color: var(--icon-color, #333);
    font-size: 1.25rem;
  }

  .feature-cards__card-title {
    font-size: 0.95rem;
    font-weight: 700;
  }

  @media (min-width: 750px) {
    .feature-cards__card-title {
      font-size: 1.05rem;
    }
  }

  .feature-cards__card-desc {
    font-size: 0.8rem;
    color: #718096;
    line-height: 1.5;
    max-width: 30ch;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.feature_cards.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.feature_cards.item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "t:labels.icon",
          "info": "t:labels.icon_info",
          "default": "fa-solid fa-star"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "t:labels.icon_color",
          "default": "#e8f5e9"
        },
        {
          "type": "color",
          "id": "icon_text_color",
          "label": "t:labels.icon_text_color",
          "default": "#333333"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.feature_cards.name",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "fa-solid fa-star",
            "icon_color": "#e8f5e9",
            "icon_text_color": "#2d6a4f",
            "title": "Feature one",
            "description": "Describe the feature here"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "fa-solid fa-heart",
            "icon_color": "#e3f2fd",
            "icon_text_color": "#1565c0",
            "title": "Feature two",
            "description": "Describe the feature here"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "fa-solid fa-bolt",
            "icon_color": "#fff3e0",
            "icon_text_color": "#e65100",
            "title": "Feature three",
            "description": "Describe the feature here"
          }
        }
      ]
    }
  ]
}
{% endschema %}
