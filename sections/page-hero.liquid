<div class="page-hero">
  <h1 class="page-hero__title">{{ section.settings.heading }}</h1>
  {% if section.settings.accent_line %}
    <span class="page-hero__accent" aria-hidden="true"></span>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="page-hero__subtitle">{{ section.settings.subheading }}</p>
  {% endif %}
  {% if section.settings.intro != blank %}
    <div class="page-hero__intro">
      {{ section.settings.intro }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .page-hero {
    text-align: center;
    padding: 16px 0 8px;
  }

  @media (min-width: 750px) {
    .page-hero {
      padding: 20px 0 12px;
    }
  }

  .page-hero__title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  @media (min-width: 750px) {
    .page-hero__title {
      font-size: 2.4rem;
    }
  }

  .page-hero__accent {
    display: block;
    width: 48px;
    height: 3px;
    margin: 12px auto 16px;
    background-color: #f4b400;
    border-radius: 2px;
  }

  .page-hero__subtitle {
    font-size: 0.95rem;
    color: #718096;
    margin: 0;
    line-height: 1.5;
  }

  .page-hero__intro {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.7;
    margin: 16px 0 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.page_hero.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Page heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:labels.intro"
    },
    {
      "type": "checkbox",
      "id": "accent_line",
      "label": "t:sections.page_hero.accent_line",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.page_hero.name"
    }
  ]
}
{% endschema %}
