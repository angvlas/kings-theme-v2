{% if section.blocks.size > 0 %}
  <div
    class="announcement full-width"
    style="--announcement-bg: {{ section.settings.bg_color }}; --announcement-fg: {{ section.settings.text_color }};"
    data-rotate-ms="{{ section.settings.rotation_speed | times: 1000 }}"
  >
    <div class="announcement__track" aria-live="polite">
      {% for block in section.blocks %}
        {% if block.type == 'message' %}
          {% liquid
            assign tag = 'span'
            if block.settings.link != blank
              assign tag = 'a'
            endif
          %}
          <{{ tag }}
            class="announcement__slide{% if forloop.first %} is-active{% endif %}"
            {% if tag == 'a' %}href="{{ block.settings.link }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            {% if block.settings.icon != blank %}
              <i class="announcement__icon {{ block.settings.icon }}" aria-hidden="true"></i>
            {% endif %}
            <span class="announcement__text">{{ block.settings.text }}</span>
          </{{ tag }}>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .announcement {
    background-color: var(--announcement-bg, #1a1a1a);
    color: var(--announcement-fg, #fff);
    position: relative;
    overflow: hidden;
  }

  /* Each header-group section becomes its own sticky element.
     Pin the announcement section at top: 0 with higher z-index,
     and offset the header section by the announcement's height. */
  .shopify-section.shopify-section-group-header-group:has(> .announcement) {
    top: 0 !important;
    z-index: 101 !important;
  }

  .shopify-section.shopify-section-group-header-group:has(> .header),
  .shopify-section.shopify-section-group-header-group:has(> .header-bar) {
    top: var(--announcement-height, 36px) !important;
  }

  .announcement__track {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    min-height: 36px;
    text-align: center;
  }

  .announcement__slide {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease;
    color: inherit;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.3;
    padding: 8px 16px;
  }

  .announcement__slide.is-active {
    opacity: 1;
    visibility: visible;
  }

  a.announcement__slide:hover .announcement__text {
    text-decoration: underline;
  }

  .announcement__icon {
    flex-shrink: 0;
    font-size: 0.9rem;
  }

  .announcement__text {
    display: inline-block;
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement__slide {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function syncHeight(bar) {
      const section = bar.closest('.shopify-section');
      const h = section ? section.offsetHeight : bar.offsetHeight;
      document.documentElement.style.setProperty('--announcement-height', h + 'px');
    }

    document.querySelectorAll('.announcement').forEach(function (bar) {
      syncHeight(bar);
      window.addEventListener('resize', function () { syncHeight(bar); });
      if (typeof ResizeObserver !== 'undefined') {
        new ResizeObserver(function () { syncHeight(bar); }).observe(bar);
      }

      const slides = bar.querySelectorAll('.announcement__slide');
      if (slides.length < 2) return;

      const interval = parseInt(bar.dataset.rotateMs, 10) || 4000;
      let index = 0;
      let timer = null;

      function show(next) {
        slides[index].classList.remove('is-active');
        index = (next + slides.length) % slides.length;
        slides[index].classList.add('is-active');
      }

      function start() {
        stop();
        timer = window.setInterval(function () { show(index + 1); }, interval);
      }

      function stop() {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
      }

      bar.addEventListener('mouseenter', stop);
      bar.addEventListener('mouseleave', start);

      start();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.announcement_bar.bg_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.announcement_bar.text_color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "t:sections.announcement_bar.rotation_speed",
      "info": "t:sections.announcement_bar.rotation_speed_info",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "t:sections.announcement_bar.message_item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.announcement_bar.message_text",
          "default": "Free shipping on orders over $100"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "t:labels.icon",
          "info": "t:labels.icon_info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.button_url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.name",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Free shipping on Australian orders over $100",
            "icon": "fa-solid fa-truck"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "New releases every Wednesday",
            "icon": "fa-solid fa-bolt"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
