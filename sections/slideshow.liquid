{% if section.blocks.size > 0 %}
  <div class="slideshow-wrapper">
  <div class="slideshow" data-slideshow data-slideshow-speed="{{ settings.slide_speed }}" aria-label="{{ 'sections.slideshow.label' | t }}">
    <div class="slideshow__track" data-slideshow-track>
      {% for block in section.blocks %}
        <div
          class="slideshow__slide{% if forloop.first %} slideshow__slide--active{% endif %}"
          data-slideshow-slide="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="slideshow__link">
          {% endif %}

          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 1800 | image_tag:
              alt: block.settings.image.alt | default: block.settings.heading | default: '',
              loading: forloop.first | default: 'lazy',
              class: 'slideshow__image slideshow__image--desktop'
            }}
          {% endif %}

          {% if block.settings.mobile_image %}
            {{ block.settings.mobile_image | image_url: width: 610 | image_tag:
              alt: block.settings.mobile_image.alt | default: block.settings.heading | default: '',
              loading: forloop.first | default: 'lazy',
              class: 'slideshow__image slideshow__image--mobile'
            }}
          {% elsif block.settings.image %}
            {{ block.settings.image | image_url: width: 610 | image_tag:
              alt: block.settings.image.alt | default: block.settings.heading | default: '',
              loading: forloop.first | default: 'lazy',
              class: 'slideshow__image slideshow__image--mobile'
            }}
          {% endif %}

          {% unless block.settings.image or block.settings.mobile_image %}
            <div class="slideshow__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
          {% endunless %}

          {% if block.settings.heading != blank or block.settings.subheading != blank %}
            <div class="slideshow__content">
              {% if block.settings.heading != blank %}
                <h2 class="slideshow__heading">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              {% if block.settings.subheading != blank %}
                <p class="slideshow__subheading">{{ block.settings.subheading | escape }}</p>
              {% endif %}
              {% if block.settings.button_text != blank %}
                <span class="slideshow__button">{{ block.settings.button_text | escape }}</span>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <button class="slideshow__arrow slideshow__arrow--prev" type="button" data-slideshow-prev aria-label="{{ 'sections.slideshow.previous' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 4L6.5 10L12.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="slideshow__arrow slideshow__arrow--next" type="button" data-slideshow-next aria-label="{{ 'sections.slideshow.next' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 4L13.5 10L7.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="slideshow__dots" data-slideshow-dots>
        {% for block in section.blocks %}
          <button
            class="slideshow__dot{% if forloop.first %} slideshow__dot--active{% endif %}"
            type="button"
            data-slideshow-dot="{{ forloop.index0 }}"
            aria-label="{{ 'sections.slideshow.slide' | t }} {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  </div>
{% endif %}

{% stylesheet %}
  .slideshow-wrapper {
    grid-column: 1 / -1;
    padding: 16px var(--page-margin) 0;
  }

  @media (min-width: 750px) {
    .slideshow-wrapper {
      padding: 20px var(--page-margin) 0;
    }
  }

  .slideshow {
    position: relative;
    overflow: hidden;
    background-color: #f7f7f8;
    border-radius: 12px;
    width: 100%;
  }

  @media (min-width: 750px) {
    .slideshow {
      border-radius: 16px;
    }
  }

  .slideshow__track {
    display: flex;
    transition: transform 0.5s ease;
  }

  .slideshow__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .slideshow__slide {
      aspect-ratio: 1800 / 610;
    }
  }

  .slideshow__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .slideshow__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slideshow__image--desktop {
    display: none;
  }

  .slideshow__image--mobile {
    display: block;
  }

  @media (min-width: 750px) {
    .slideshow__image--desktop {
      display: block;
    }

    .slideshow__image--mobile {
      display: none;
    }
  }

  .slideshow__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e2e2e4;
  }

  .slideshow__placeholder svg {
    width: 50%;
    max-width: 300px;
    height: auto;
    opacity: 0.3;
  }

  /* Content overlay */
  .slideshow__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  @media (min-width: 750px) {
    .slideshow__content {
      padding: 40px 48px;
      gap: 8px;
    }
  }

  .slideshow__heading {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.2;
  }

  @media (min-width: 750px) {
    .slideshow__heading {
      font-size: 2.4rem;
    }
  }

  .slideshow__subheading {
    font-size: 0.85rem;
    opacity: 0.85;
  }

  @media (min-width: 750px) {
    .slideshow__subheading {
      font-size: 1rem;
    }
  }

  .slideshow__button {
    display: inline-block;
    margin-top: 8px;
    padding: 10px 24px;
    background-color: #fff;
    color: #333;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 8px;
    align-self: flex-start;
    transition: opacity 0.15s ease;
  }

  .slideshow__link:hover .slideshow__button {
    opacity: 0.9;
  }

  /* Arrows */
  .slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: #333;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: background-color 0.15s ease;
    display: none;
  }

  .slideshow__arrow:hover {
    background-color: #fff;
  }

  .slideshow__arrow--prev {
    left: 12px;
  }

  .slideshow__arrow--next {
    right: 12px;
  }

  @media (min-width: 750px) {
    .slideshow__arrow {
      display: flex;
      width: 44px;
      height: 44px;
    }

    .slideshow__arrow--prev {
      left: 20px;
    }

    .slideshow__arrow--next {
      right: 20px;
    }
  }

  /* Dots */
  .slideshow__dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    gap: 8px;
  }

  @media (min-width: 750px) {
    .slideshow__dots {
      bottom: 20px;
    }
  }

  .slideshow__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background-color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .slideshow__dot:hover {
    background-color: rgba(255, 255, 255, 0.8);
  }

  .slideshow__dot--active {
    background-color: #fff;
    transform: scale(1.25);
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var slideshow = document.querySelector('[data-slideshow]');
    if (!slideshow) return;

    var track = slideshow.querySelector('[data-slideshow-track]');
    var slides = slideshow.querySelectorAll('[data-slideshow-slide]');
    var dots = slideshow.querySelectorAll('[data-slideshow-dot]');
    var prevBtn = slideshow.querySelector('[data-slideshow-prev]');
    var nextBtn = slideshow.querySelector('[data-slideshow-next]');
    var current = 0;
    var total = slides.length;
    var autoplayInterval = null;
    var autoplayDelay = (parseInt(slideshow.getAttribute('data-slideshow-speed'), 10) || 5) * 1000;

    if (total <= 1) return;

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      current = index;

      track.style.transform = 'translateX(-' + (current * 100) + '%)';

      slides.forEach(function(s, i) {
        s.classList.toggle('slideshow__slide--active', i === current);
      });

      dots.forEach(function(d, i) {
        d.classList.toggle('slideshow__dot--active', i === current);
      });
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAutoplay() {
      stopAutoplay();
      autoplayInterval = setInterval(next, autoplayDelay);
    }

    function stopAutoplay() {
      if (autoplayInterval) clearInterval(autoplayInterval);
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAutoplay(); });

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var index = parseInt(this.getAttribute('data-slideshow-dot'), 10);
        goTo(index);
        startAutoplay();
      });
    });

    /* Touch swipe */
    var startX = 0;
    var isDragging = false;

    slideshow.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      isDragging = true;
      stopAutoplay();
    }, { passive: true });

    slideshow.addEventListener('touchend', function(e) {
      if (!isDragging) return;
      isDragging = false;
      var diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) next(); else prev();
      }
      startAutoplay();
    });

    /* Pause on hover */
    slideshow.addEventListener('mouseenter', stopAutoplay);
    slideshow.addEventListener('mouseleave', startAutoplay);

    startAutoplay();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.slide_image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "t:labels.slide_mobile_image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.slide_link"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.slide_heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:labels.slide_subheading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:labels.slide_button_text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.name",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
