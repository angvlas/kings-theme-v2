<div class="email-signup">
  <div class="email-signup__inner">
    <div class="email-signup__text">
      {% if section.settings.heading != blank %}
        <h2 class="email-signup__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.intro != blank %}
        <p class="email-signup__intro">{{ section.settings.intro }}</p>
      {% endif %}
    </div>

    {% form 'customer', class: 'email-signup__form' %}
      <input type="hidden" name="contact[tags]" value="{{ section.settings.form_tag | default: 'newsletter' }}">

      {% if form.posted_successfully? %}
        <div class="email-signup__success" role="status">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="#38a169" stroke-width="1.5"/>
            <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#38a169" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p>{{ section.settings.success_message }}</p>
        </div>
      {% else %}
        {% if form.errors %}
          <div class="email-signup__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="email-signup__row">
          <label for="email-signup-email" class="visually-hidden">
            {{ 'sections.email_signup.field_email' | t }}
          </label>
          <input
            type="email"
            id="email-signup-email"
            name="contact[email]"
            class="email-signup__input"
            placeholder="{{ 'sections.email_signup.field_email_placeholder' | t }}"
            required
            autocomplete="email"
            value="{% if customer %}{{ customer.email }}{% endif %}"
          >
          <button type="submit" class="email-signup__submit">
            {{ section.settings.submit_label }}
          </button>
        </div>

        {% if section.settings.fine_print != blank %}
          <p class="email-signup__fine-print">{{ section.settings.fine_print }}</p>
        {% endif %}
      {% endif %}
    {% endform %}
  </div>
</div>

{% stylesheet %}
  .email-signup {
    padding: 16px 0;
  }

  @media (min-width: 750px) {
    .email-signup {
      padding: 20px 0;
    }
  }

  .email-signup__inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background-color: #fff;
    color: #1a1a1a;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 0, 0, 0.05);
  }

  @media (min-width: 750px) {
    .email-signup__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      padding: 28px 32px;
    }
  }

  .email-signup__text {
    flex: 1;
    min-width: 0;
  }

  .email-signup__title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 4px;
  }

  @media (min-width: 750px) {
    .email-signup__title {
      font-size: 1.5rem;
    }
  }

  .email-signup__intro {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  .email-signup__form {
    flex: 1;
    max-width: 480px;
    width: 100%;
  }

  .email-signup__row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (min-width: 600px) {
    .email-signup__row {
      flex-direction: row;
      gap: 8px;
    }
  }

  .email-signup__input {
    flex: 1;
    padding: 12px 14px;
    border: 1px solid #e2e2e4;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1a1a1a;
    background-color: #fff;
    transition: border-color 0.15s ease;
    min-width: 0;
  }

  .email-signup__input:focus {
    outline: none;
    border-color: #1a1a1a;
  }

  .email-signup__submit {
    padding: 12px 24px;
    background-color: #f4b400;
    color: #1a1a1a;
    border: none;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s ease;
    flex-shrink: 0;
  }

  .email-signup__submit:hover {
    opacity: 0.9;
  }

  .email-signup__fine-print {
    font-size: 0.75rem;
    color: #777;
    margin: 8px 0 0;
    line-height: 1.4;
  }

  .email-signup__success {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    background-color: #f0fff4;
    border: 1px solid #c6f6d5;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #38a169;
    font-weight: 500;
  }

  .email-signup__success p {
    margin: 0;
  }

  .email-signup__errors {
    padding: 12px 14px;
    margin-bottom: 12px;
    background-color: #fff5f5;
    border: 1px solid #fed7d7;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #e53e3e;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.email_signup.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "t:labels.intro",
      "default": "Subscribe to hear about new releases, exclusive drops and store news."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "t:labels.button_label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "t:labels.success_message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "t:labels.fine_print",
      "info": "t:labels.fine_print_info"
    },
    {
      "type": "header",
      "content": "t:labels.contact_form_meta"
    },
    {
      "type": "text",
      "id": "form_tag",
      "label": "t:labels.form_tag",
      "info": "t:labels.form_tag_info",
      "default": "newsletter"
    }
  ],
  "presets": [
    {
      "name": "t:sections.email_signup.name"
    }
  ]
}
{% endschema %}
