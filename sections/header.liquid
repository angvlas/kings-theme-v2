{% liquid
  assign has_top_bar = false
  if section.settings.top_menu.links.size > 0 or section.settings.contact_email != blank or section.settings.contact_phone != blank or settings.social_facebook != blank or settings.social_instagram != blank or settings.social_twitter != blank or settings.social_tiktok != blank or settings.social_youtube != blank
    assign has_top_bar = true
  endif
%}

{% if has_top_bar %}
  <div class="header-bar header-bar--top">
    <div class="header-bar__inner">
      {% if section.settings.top_menu.links.size > 0 %}
        <nav class="header-bar__left" aria-label="{{ 'header.top_navigation' | t }}">
          {% for link in section.settings.top_menu.links %}
            <a href="{{ link.url }}" class="header-bar__link">{{ link.title }}</a>
          {% endfor %}
        </nav>
      {% endif %}

      <div class="header-bar__right">
        {% if section.settings.contact_email != blank %}
          <a href="mailto:{{ section.settings.contact_email }}" class="header-bar__contact">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="2" y="3" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/>
              <path d="M2 5l6 4 6-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.contact_email }}
          </a>
        {% endif %}

        {% if section.settings.contact_phone != blank %}
          <a href="tel:{{ section.settings.contact_phone | remove: ' ' | remove: '(' | remove: ')' }}" class="header-bar__contact">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 2h3l1 3.5-1.5 1a8 8 0 0 0 3.5 3.5l1-1.5L14 9.5v3a1.5 1.5 0 0 1-1.5 1.5A11.5 11.5 0 0 1 2 3.5 1.5 1.5 0 0 1 3.5 2Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.contact_phone }}
          </a>
        {% endif %}

        {% if settings.social_facebook != blank %}
          <a href="{{ settings.social_facebook }}" class="header-bar__social" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 1.5C5.3 1.5 1.5 5.3 1.5 10c0 4.24 3.11 7.76 7.17 8.39v-5.93H6.5V10h2.17V8.17c0-2.14 1.27-3.33 3.23-3.33.94 0 1.92.17 1.92.17v2.1h-1.08c-1.07 0-1.4.66-1.4 1.34V10h2.37l-.38 2.46h-1.99v5.93c4.06-.63 7.17-4.15 7.17-8.39 0-4.7-3.8-8.5-8.5-8.5Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" class="header-bar__social" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="16" height="16" rx="5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="14.5" cy="5.5" r="1" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if settings.social_twitter != blank %}
          <a href="{{ settings.social_twitter }}" class="header-bar__social" aria-label="X / Twitter" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M11.2 9.05L16.5 3h-1.26l-4.6 5.25L7.3 3H3l5.56 7.95L3 17.5h1.26l4.86-5.55 3.88 5.55H17L11.2 9.05Zm-1.72 1.96l-.56-.79L4.95 4h1.93l3.62 5.1.56.79 4.7 6.61h-1.93l-3.83-5.49Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" class="header-bar__social" aria-label="TikTok" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M14.5 2h-2.4v10.9c0 1.3-1.1 2.4-2.4 2.4s-2.4-1.1-2.4-2.4 1.1-2.4 2.4-2.4c.3 0 .5 0 .7.1V8.2c-.2 0-.5-.1-.7-.1-3 0-5.4 2.4-5.4 5.4S6.7 19 9.7 19s5.4-2.4 5.4-5.4V7.8c1 .7 2.2 1.2 3.4 1.2V6.6c-2 0-4-1.6-4-4.6Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if settings.social_youtube != blank %}
          <a href="{{ settings.social_youtube }}" class="header-bar__social" aria-label="YouTube" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M17.8 6.2c-.2-.7-.8-1.3-1.5-1.5C15 4.3 10 4.3 10 4.3s-5 0-6.3.4c-.7.2-1.3.8-1.5 1.5C1.8 7.5 1.8 10 1.8 10s0 2.5.4 3.8c.2.7.8 1.3 1.5 1.5 1.3.4 6.3.4 6.3.4s5 0 6.3-.4c.7-.2 1.3-.8 1.5-1.5.4-1.3.4-3.8.4-3.8s0-2.5-.4-3.8Z" fill="currentColor"/>
              <path d="M8.3 12.5l4.2-2.5-4.2-2.5v5Z" fill="#fff"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

<header class="header" role="banner">
  <div class="header__inner">
    <button
      class="header__menu-toggle"
      type="button"
      aria-label="{{ 'header.menu' | t }}"
      aria-controls="mobile-drawer"
      aria-expanded="false"
      data-drawer-toggle
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="header__logo">
      {% if section.settings.logo %}
        {{ section.settings.logo | image_url: height: 40 | image_tag: class: 'header__logo-image', alt: shop.name }}
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <div class="header__search" data-instant-search>
      <form action="{{ routes.search_url }}" method="get" class="header__search-form" role="search">
        <svg class="header__search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M11 11L14.5 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          name="q"
          class="header__search-input"
          placeholder="{{ 'header.search_placeholder' | t }}"
          aria-label="{{ 'header.search_placeholder' | t }}"
          autocomplete="off"
          data-instant-search-input
        >
        <input type="hidden" name="type" value="{{ section.settings.search_type }}">
      </form>
      <div class="instant-search" data-instant-search-results hidden>
        <div class="instant-search__body" data-instant-search-body></div>
        <a href="#" class="instant-search__view-all" data-instant-search-view-all hidden>
          {{ 'header.view_all_results' | t }}
        </a>
      </div>
    </div>

    <div class="header__actions">
      {% if section.settings.shipment_status != 'hidden' %}
        <div class="header__shipment-status header__shipment-status--{{ section.settings.shipment_status }}">
          <span class="header__shipment-dot"></span>
          <span class="header__shipment-label">{{ section.settings.shipment_text }}</span>
        </div>
      {% endif %}
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="header__action" aria-label="{{ 'header.account' | t }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3.5 17.5c0-3.59 2.91-6.5 6.5-6.5s6.5 2.91 6.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      {% endif %}

      <button type="button" class="header__action header__cart" aria-label="{{ 'header.cart' | t }}" data-cart-toggle>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4h1.5l1 9h9l1.5-6H6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8" cy="16" r="1.5" fill="currentColor"/>
          <circle cx="14" cy="16" r="1.5" fill="currentColor"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </button>
    </div>
  </div>
</header>

{% comment %} Cart drawer {% endcomment %}
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>
  <div class="cart-drawer__body">
    <div class="cart-drawer__header">
      <span class="cart-drawer__title">{{ 'cart.title' | t }} (<span data-cart-drawer-count>{{ cart.item_count }}</span>)</span>
      <button class="cart-drawer__close" type="button" aria-label="{{ 'header.close' | t }}" data-cart-drawer-close>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 4L14 14M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__items" data-cart-drawer-items>
      {% for item in cart.items %}
        <div class="cart-drawer__item" data-cart-drawer-item data-line-key="{{ item.key }}" data-inventory-quantity="{{ item.variant.inventory_quantity }}" data-inventory-policy="{{ item.variant.inventory_policy }}">
          <a href="{{ item.url }}" class="cart-drawer__item-image">
            {% if item.image %}
              {{ item.image | image_url: width: 120 | image_tag: alt: item.product.title, loading: 'lazy' }}
            {% endif %}
          </a>
          <div class="cart-drawer__item-info">
            <a href="{{ item.url }}" class="cart-drawer__item-name">{{ item.product.title }}</a>
            {% if item.variant.title != 'Default Title' %}
              <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
            {% endif %}
            <div class="cart-drawer__item-price-row">
              <span class="cart-drawer__item-price" data-drawer-line-total>{{ item.line_price | money }}</span>
              {% if item.variant.compare_at_price > item.price %}
                <span class="cart-drawer__item-compare-price">{{ item.variant.compare_at_price | money }}</span>
                {% assign discount_pct = item.variant.compare_at_price | minus: item.price | times: 100 | divided_by: item.variant.compare_at_price %}
                <span class="cart-drawer__item-discount">-{{ discount_pct }}%</span>
              {% elsif item.quantity > 1 %}
                <span class="cart-drawer__item-unit-price">{{ item.price | money }} {{ 'cart.each' | t }}</span>
              {% endif %}
            </div>
            <div class="cart-drawer__item-qty">
              <button type="button" class="cart-drawer__qty-btn" data-drawer-qty-minus>-</button>
              <span class="cart-drawer__qty-value" data-drawer-qty-value>{{ item.quantity }}</span>
              <button type="button" class="cart-drawer__qty-btn" data-drawer-qty-plus>+</button>
              <button type="button" class="cart-drawer__item-remove" data-drawer-remove aria-label="{{ 'cart.remove' | t }}">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="cart-drawer__empty" data-cart-drawer-empty {% if cart.item_count > 0 %}hidden{% endif %}>
      <p>{{ 'cart.empty' | t }}</p>
    </div>

    <div class="cart-drawer__footer" data-cart-drawer-footer {% if cart.item_count == 0 %}hidden{% endif %}>
      {% for i in (1..3) %}
        {% assign notice_key = 'cart_notice_' | append: i %}
        {% assign notice_text = settings[notice_key] %}
        {% if notice_text != blank %}
          <div class="cart-drawer__notice">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
              <path d="M8 5v3.5M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>{{ notice_text }}</span>
          </div>
        {% endif %}
      {% endfor %}
      <div class="cart-drawer__subtotal">
        <span>{{ 'cart.subtotal' | t }}</span>
        <span data-cart-drawer-subtotal>{{ cart.total_price | money }}</span>
      </div>
      <p class="cart-drawer__taxes">{{ 'cart.taxes_note' | t }}</p>
      <a href="/checkout" class="cart-drawer__checkout">{{ 'cart.checkout' | t }}</a>
      <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">{{ 'cart.view_cart' | t }}</a>
    </div>
  </div>
</div>

{% comment %} Mobile drawer {% endcomment %}
<div class="mobile-drawer" id="mobile-drawer" hidden>
  <div class="mobile-drawer__overlay" data-drawer-close></div>
  <div class="mobile-drawer__body">
    <div class="mobile-drawer__header">
      <span class="mobile-drawer__title">{{ 'header.menu' | t }}</span>
      <button class="mobile-drawer__close" type="button" aria-label="{{ 'header.close' | t }}" data-drawer-close>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 4L14 14M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-drawer__nav" aria-label="{{ 'header.main_navigation' | t }}">
      {% if section.settings.bottom_menu.links.size > 0 %}
        <ul class="mobile-nav">
          {% for link in section.settings.bottom_menu.links %}
            <li class="mobile-nav__item">
              <div class="mobile-nav__row">
                <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
                {% if link.links.size > 0 %}
                  <button class="mobile-nav__expand" type="button" aria-expanded="false" data-mobile-expand>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                {% endif %}
              </div>
              {% if link.links.size > 0 %}
                <ul class="mobile-nav__sub" hidden>
                  {% for child in link.links %}
                    <li class="mobile-nav__item">
                      <div class="mobile-nav__row">
                        <a href="{{ child.url }}" class="mobile-nav__link mobile-nav__link--sub">{{ child.title }}</a>
                        {% if child.links.size > 0 %}
                          <button class="mobile-nav__expand" type="button" aria-expanded="false" data-mobile-expand>
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                              <path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </button>
                        {% endif %}
                      </div>
                      {% if child.links.size > 0 %}
                        <ul class="mobile-nav__sub" hidden>
                          {% for grandchild in child.links %}
                            <li class="mobile-nav__item">
                              <div class="mobile-nav__row">
                                <a href="{{ grandchild.url }}" class="mobile-nav__link mobile-nav__link--deep">{{ grandchild.title }}</a>
                                {% if grandchild.links.size > 0 %}
                                  <button class="mobile-nav__expand" type="button" aria-expanded="false" data-mobile-expand>
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                                      <path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </button>
                                {% endif %}
                              </div>
                              {% if grandchild.links.size > 0 %}
                                <ul class="mobile-nav__sub" hidden>
                                  {% for item in grandchild.links %}
                                    <li class="mobile-nav__item">
                                      <a href="{{ item.url }}" class="mobile-nav__link mobile-nav__link--deep">{{ item.title }}</a>
                                    </li>
                                  {% endfor %}
                                </ul>
                              {% endif %}
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if section.settings.extra_menu.links.size > 0 %}
        <ul class="mobile-nav mobile-nav--extra">
          {% for link in section.settings.extra_menu.links %}
            <li class="mobile-nav__item">
              <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>
  </div>
</div>

{% if section.settings.bottom_menu.links.size > 0 %}
  <div class="header-bar header-bar--bottom">
    <nav class="mega-nav" aria-label="{{ 'header.main_navigation' | t }}">
      <ul class="mega-nav__list">
        {% comment %}
          Level 1: Menu title displayed as the nav bar trigger.
          Level 2: Direct children become left column categories.
          Level 3: Grandchildren become right panel group headings.
          Level 4: Great-grandchildren become links under headings.
        {% endcomment %}
        <li class="mega-nav__item mega-nav__item--has-children">
          <a href="{{ section.settings.bottom_menu.links.first.url | default: '#' }}" class="mega-nav__link">
            {{ section.settings.bottom_menu.title }}
            <svg class="mega-nav__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2.5 3.5L5 6.5L7.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <div class="mega-nav__panel">
            <div class="mega-nav__panel-inner">
              <ul class="mega-nav__categories">
                {% for link in section.settings.bottom_menu.links %}
                  <li class="mega-nav__category{% if forloop.first %} mega-nav__category--active{% endif %}" data-mega-category>
                    <a href="{{ link.url }}" class="mega-nav__category-link">
                      <span>{{ link.title }}</span>
                      {% if link.links.size > 0 %}
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                          <path d="M3.5 2.5L6.5 5L3.5 7.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% endif %}
                    </a>
                  </li>
                {% endfor %}
              </ul>

              <div class="mega-nav__content">
                {% for link in section.settings.bottom_menu.links %}
                  <div class="mega-nav__subcontent{% if forloop.first %} mega-nav__subcontent--active{% endif %}" data-mega-content="{{ link.title | handleize }}">
                    {% if link.links.size > 0 %}
                      <div class="mega-nav__columns">
                        {% for group in link.links %}
                          <div class="mega-nav__column">
                            <p class="mega-nav__column-title">
                              <a href="{{ group.url }}" class="mega-nav__column-title-link">{{ group.title }}</a>
                            </p>
                            {% if group.links.size > 0 %}
                              <ul class="mega-nav__column-list">
                                {% for item in group.links %}
                                  <li>
                                    <a href="{{ item.url }}" class="mega-nav__column-link">{{ item.title }}</a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% endif %}
                          </div>
                        {% endfor %}
                      </div>
                    {% else %}
                      <p class="mega-nav__empty">
                        <a href="{{ link.url }}" class="mega-nav__column-link">{{ 'header.view_all' | t }} {{ link.title }}</a>
                      </p>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        {% if section.settings.extra_menu.links.size > 0 %}
          {% for link in section.settings.extra_menu.links %}
            <li class="mega-nav__item">
              <a href="{{ link.url }}" class="mega-nav__link{% if link.active %} mega-nav__link--active{% endif %}">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        {% endif %}
      </ul>

      {% if section.settings.right_menu.links.size > 0 %}
        <ul class="mega-nav__list mega-nav__list--right">
          {% for link in section.settings.right_menu.links %}
            <li class="mega-nav__item">
              <a href="{{ link.url }}" class="mega-nav__link{% if link.active %} mega-nav__link--active{% endif %}">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>
  </div>
{% endif %}

<div data-header-config hidden
  data-section-id="{{ section.id }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-no-results="{{ 'search.no_results' | t | escape }}"
  data-searching="{{ 'header.searching' | t | escape }}"
  data-search-error="{{ 'header.search_error' | t | escape }}"
  data-type-article="{{ 'header.type_article' | t | escape }}"
  data-type-page="{{ 'header.type_page' | t | escape }}"
  data-each="{{ 'cart.each' | t | escape }}"
  data-only-available="{{ 'cart.only_x_available' | t | escape }}"
  data-remove-label="{{ 'cart.remove' | t | escape }}"
></div>

{% stylesheet %}
  /* Make entire header section sticky */
  .shopify-section-group-header-group {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* Force header section children to span full width */
  .header-bar,
  .header {
    grid-column: 1 / -1;
  }

  /* Top bar */
  .header-bar {
    background-color: #444;
  }

  .header-bar--top {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .header-bar__left {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .header-bar__right {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
  }

  .header-bar__link {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 4px;
    transition: color 0.15s ease;
  }

  .header-bar__link:hover {
    color: #fff;
  }

  .header-bar__contact {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .header-bar__contact:hover {
    color: #fff;
  }

  .header-bar__contact svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .header-bar__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.15s ease;
  }

  .header-bar__social:hover {
    color: #fff;
  }

  /* Bottom bar */
  .header-bar--bottom {
    background-color: #fff;
    border-top: none;
    border-bottom: 1px solid #e2e2e4;
    position: relative;
    z-index: 99;
  }

  /* Mega nav */
  .mega-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .mega-nav__list {
    display: flex;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mega-nav__list--right {
    margin-left: auto;
  }

  .mega-nav__item {
    position: static;
  }

  .mega-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 10px 14px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-foreground, #333);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 6px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .mega-nav__link:hover {
    color: var(--color-foreground, #333);
    background-color: #f0f0f2;
  }

  .mega-nav__link--active {
    font-weight: 700;
    background-color: #f0f0f2;
  }

  .mega-nav__chevron {
    color: #9b9ba0;
    transition: transform 0.2s ease;
  }

  .mega-nav__item:hover > .mega-nav__link > .mega-nav__chevron {
    transform: rotate(180deg);
  }

  /* Panel — full-width dropdown */
  .mega-nav__panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    background-color: var(--color-background, #fff);
    border-top: 1px solid #e2e2e4;
    border-bottom: 1px solid #e2e2e4;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, visibility 0.15s ease;
  }

  .mega-nav__item:hover > .mega-nav__panel {
    opacity: 1;
    visibility: visible;
  }

  .mega-nav__panel-inner {
    display: flex;
    margin: 0 auto;
    padding: 0 var(--page-margin);
    min-height: 320px;
  }

  /* Left column — categories */
  .mega-nav__categories {
    list-style: none;
    padding: 16px 0;
    margin: 0;
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid #e2e2e4;
    overflow-y: auto;
  }

  .mega-nav__category-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 24px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #718096;
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .mega-nav__category-link:hover,
  .mega-nav__category--active > .mega-nav__category-link {
    color: var(--color-foreground, #333);
    font-weight: 700;
    background-color: #f7f7f8;
  }

  .mega-nav__category-link svg {
    flex-shrink: 0;
    color: #9b9ba0;
  }

  /* Right content — subcategories in columns */
  .mega-nav__content {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .mega-nav__subcontent {
    display: none;
    padding: 24px 32px;
  }

  .mega-nav__subcontent--active {
    display: block;
  }

  .mega-nav__columns {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 28px 36px;
  }

  .mega-nav__empty {
    padding: 4px 0;
  }

  .mega-nav__column-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-foreground, #333);
    margin-bottom: 12px;
  }

  .mega-nav__column-title-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .mega-nav__column-title-link:hover {
    text-decoration: underline;
  }

  .mega-nav__column-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mega-nav__column-link {
    font-size: 0.85rem;
    color: #718096;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .mega-nav__column-link:hover {
    color: var(--color-foreground, #333);
  }


  /* Header */
  .header {
    background-color: #333;
    border-bottom: none;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 56px;
    margin: 0 auto;
    padding: 0 var(--page-margin);
    position: relative;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .header__logo-image {
    height: 32px;
    width: auto;
  }

  .header__logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    color: #fff;
  }

  .header__search {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px;
  }

  .header__search-form {
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: #222;
    border-radius: 6px;
    padding: 0 12px;
    transition: border-color 0.15s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header__search-form:focus-within {
    border-color: rgba(255, 255, 255, 0.3);
  }

  .header__search-icon {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.4);
  }

  .header__search-input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    padding: 10px 0;
    font-size: 0.85rem;
    font-family: inherit;
    color: #fff;
  }

  .header__search-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .header__search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .header__shipment-status {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .header__shipment-status--on_time { background: rgba(56,161,105,0.15); color: #68d391; }
  .header__shipment-status--delayed { background: rgba(214,158,46,0.15); color: #ecc94b; }
  .header__shipment-dot { width: 7px; height: 7px; border-radius: 50%; }
  .header__shipment-status--on_time .header__shipment-dot { background: #38a169; }
  .header__shipment-status--delayed .header__shipment-dot { background: #d69e2e; }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: #fff;
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
    transition: background-color 0.15s ease;
  }

  .header__action:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .header__cart {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background-color: #e53e3e;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Instant search dropdown */
  .instant-search {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 101;
    background-color: var(--color-background, #fff);
    border: 1px solid #e2e2e4;
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    max-height: 420px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .instant-search[hidden] {
    display: none;
  }

  .instant-search__body {
    overflow-y: auto;
    padding: 8px;
    flex: 1;
  }

  .instant-search__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.1s ease;
  }

  .instant-search__item:hover,
  .instant-search__item--active {
    background-color: #f7f7f8;
  }

  .instant-search__item-image {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    background-color: #f7f7f8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .instant-search__item-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .instant-search__item-info {
    flex: 1;
    min-width: 0;
  }

  .instant-search__item-title {
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .instant-search__item-meta {
    font-size: 0.7rem;
    color: #9b9ba0;
    margin-top: 2px;
  }

  .instant-search__item-price {
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .instant-search__empty {
    padding: 24px;
    text-align: center;
    font-size: 0.85rem;
    color: #9b9ba0;
  }

  .instant-search__loading {
    padding: 24px;
    text-align: center;
    font-size: 0.8rem;
    color: #9b9ba0;
  }

  .instant-search__view-all {
    display: block;
    padding: 12px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
    text-decoration: none;
    border-top: 1px solid #e2e2e4;
    transition: background-color 0.1s ease;
  }

  .instant-search__view-all:hover {
    background-color: #f7f7f8;
  }

  .instant-search__view-all[hidden] {
    display: none;
  }

  /* Cart drawer */
  .cart-drawer {
    visibility: hidden;
    pointer-events: none;
    transition: visibility 0s linear 0.25s;
  }

  .cart-drawer--open {
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s;
  }

  .cart-drawer__overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background-color: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .cart-drawer--open .cart-drawer__overlay {
    opacity: 1;
  }

  .cart-drawer__body {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 201;
    width: 380px;
    max-width: 90vw;
    background-color: var(--color-background, #fff);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.25s ease;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.1);
  }

  .cart-drawer--open .cart-drawer__body {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e2e2e4;
    flex-shrink: 0;
  }

  .cart-drawer__title {
    font-size: 1rem;
    font-weight: 700;
  }

  .cart-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--color-foreground, #333);
    cursor: pointer;
    border-radius: 6px;
  }

  .cart-drawer__close:hover {
    background-color: #f7f7f8;
  }

  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }

  .cart-drawer__item {
    display: flex;
    gap: 12px;
    padding: 14px 20px;
    border-bottom: 1px solid #f0f0f2;
  }

  .cart-drawer__item-image {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    background-color: #f7f7f8;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__item-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cart-drawer__item-info {
    flex: 1;
    min-width: 0;
  }

  .cart-drawer__item-name {
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cart-drawer__item-name:hover {
    text-decoration: underline;
  }

  .cart-drawer__item-variant {
    font-size: 0.7rem;
    color: #9b9ba0;
    margin-top: 2px;
  }

  .cart-drawer__item-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 4px;
  }

  .cart-drawer__item-price {
    font-size: 0.8rem;
    font-weight: 700;
  }

  .cart-drawer__item-unit-price {
    font-size: 0.65rem;
    color: #9b9ba0;
  }

  .cart-drawer__item-compare-price { font-size: 0.7rem; color: #9b9ba0; text-decoration: line-through; }
  .cart-drawer__item-discount { display: inline-flex; align-items: center; padding: 2px 6px; background: #e53e3e; color: #fff; font-size: 0.6rem; font-weight: 700; border-radius: 4px; line-height: 1; }

  .cart-drawer__item-qty {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
  }

  .cart-drawer__qty-btn {
    width: 26px;
    height: 26px;
    border: 1px solid #e2e2e4;
    border-radius: 5px;
    background: transparent;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground, #333);
    font-family: inherit;
    transition: border-color 0.15s ease;
  }

  .cart-drawer__qty-btn:hover:not(:disabled) {
    border-color: var(--color-foreground, #333);
  }

  .cart-drawer__qty-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .cart-drawer__qty-value {
    font-size: 0.8rem;
    font-weight: 600;
    min-width: 20px;
    text-align: center;
  }

  .cart-drawer__item-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border: none;
    background: transparent;
    color: #9b9ba0;
    cursor: pointer;
    border-radius: 5px;
    margin-left: auto;
    transition: color 0.15s ease;
  }

  .cart-drawer__item-remove:hover {
    color: #e53e3e;
  }

  .cart-drawer__item-warning {
    font-size: 0.7rem;
    color: #e53e3e;
    font-weight: 500;
    margin-top: 4px;
    animation: drawer-warn-fade 3s ease forwards;
  }

  @keyframes drawer-warn-fade {
    0%, 80% { opacity: 1; }
    100% { opacity: 0; }
  }

  .cart-drawer__empty {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9b9ba0;
    font-size: 0.9rem;
  }

  .cart-drawer__empty[hidden] {
    display: none;
  }

  .cart-drawer__footer {
    padding: 16px 20px;
    border-top: 1px solid #e2e2e4;
    flex-shrink: 0;
  }

  .cart-drawer__footer[hidden] {
    display: none;
  }

  .cart-drawer__notice {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 12px;
    background-color: #fef3c7;
    color: #92400e;
    border-radius: 8px;
    font-size: 0.75rem;
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .cart-drawer__notice:last-of-type {
    margin-bottom: 12px;
  }

  .cart-drawer__notice svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: #d97706;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .cart-drawer__taxes {
    font-size: 0.7rem;
    color: #9b9ba0;
    margin-bottom: 14px;
  }

  .cart-drawer__checkout {
    display: block;
    width: 100%;
    padding: 12px;
    text-align: center;
    background-color: var(--color-foreground, #333);
    color: var(--color-background, #fff);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s ease;
    margin-bottom: 8px;
  }

  .cart-drawer__checkout:hover {
    opacity: 0.9;
  }

  .cart-drawer__view-cart {
    display: block;
    width: 100%;
    padding: 10px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
    text-decoration: none;
    border: 1px solid #e2e2e4;
    border-radius: 8px;
    transition: border-color 0.15s ease;
  }

  .cart-drawer__view-cart:hover {
    border-color: var(--color-foreground, #333);
  }

  /* Hamburger toggle — mobile only */
  .header__menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Mobile drawer */
  .mobile-drawer {
    display: none;
  }

  .mobile-drawer[hidden] {
    display: none;
  }

  .mobile-drawer--open {
    display: block;
  }

  .mobile-drawer__overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background-color: rgba(0, 0, 0, 0.4);
  }

  .mobile-drawer__body {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 201;
    width: 300px;
    max-width: 85vw;
    background-color: var(--color-background, #fff);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
  }

  .mobile-drawer--open .mobile-drawer__body {
    transform: translateX(0);
  }

  .mobile-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e2e2e4;
  }

  .mobile-drawer__title {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .mobile-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--color-foreground, #333);
    cursor: pointer;
    border-radius: 6px;
  }

  .mobile-drawer__close:hover {
    background-color: #f7f7f8;
  }

  .mobile-drawer__nav {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }

  /* Mobile nav accordion */
  .mobile-nav {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav--extra {
    border-top: 1px solid #e2e2e4;
    margin-top: 8px;
    padding-top: 8px;
  }

  .mobile-nav__row {
    display: flex;
    align-items: center;
  }

  .mobile-nav__link {
    flex: 1;
    padding: 10px 20px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
    text-decoration: none;
  }

  .mobile-nav__link--sub {
    font-weight: 500;
    padding-left: 32px;
  }

  .mobile-nav__link--deep {
    font-weight: 400;
    font-size: 0.85rem;
    color: #718096;
    padding-left: 44px;
  }

  .mobile-nav__expand {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    color: #9b9ba0;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .mobile-nav__expand[aria-expanded="true"] {
    transform: rotate(180deg);
  }

  .mobile-nav__sub {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav__sub[hidden] {
    display: none;
  }

  /* Desktop */
  @media (max-width: 749px) {
    .header__menu-toggle {
      display: flex;
    }

    .header__search {
      display: none;
    }

    .header__shipment-status {
      display: none;
    }

    .header__inner {
      justify-content: space-between;
    }

    .header-bar--top {
      display: none;
    }

    .header-bar--bottom {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var configEl = document.querySelector('[data-header-config]');
    function attr(name) { return configEl ? configEl.getAttribute('data-' + name) || '' : ''; }
    var moneyFormat = attr('money-format');
    var strings = {
      noResults: attr('no-results'),
      searching: attr('searching'),
      searchError: attr('search-error'),
      typeArticle: attr('type-article'),
      typePage: attr('type-page'),
      each: attr('each'),
      onlyXAvailable: attr('only-available'),
      removeLabel: attr('remove-label')
    };

    function formatMoney(cents) {
      if (!moneyFormat) return (cents / 100).toFixed(2);
      var amount = (cents / 100).toFixed(2);
      var amountNoDecimals = Math.round(cents / 100).toString();
      var amountWithComma = amount.replace('.', ',');
      return moneyFormat
        .replace(new RegExp('[{][{]amount_with_comma_separator[}][}]'), amountWithComma)
        .replace(new RegExp('[{][{]amount_no_decimals[}][}]'), amountNoDecimals)
        .replace(new RegExp('[{][{]amount_no_decimals_with_comma_separator[}][}]'), amountNoDecimals)
        .replace(new RegExp('[{][{]amount[}][}]'), amount);
    }

    function initDrawer(el, openClass, closeSel, onOpen, onClose) {
      function open() {
        el.classList.add(openClass);
        document.body.style.overflow = 'hidden';
        if (onOpen) onOpen();
      }
      function close() {
        el.classList.remove(openClass);
        document.body.style.overflow = '';
        if (onClose) onClose();
      }
      el.querySelectorAll(closeSel).forEach(function(btn) {
        btn.addEventListener('click', close);
      });
      return { open: open, close: close };
    }

    /* Desktop mega nav hover */
    document.querySelectorAll('.mega-nav__item--has-children').forEach(function(item) {
      var categories = item.querySelectorAll('[data-mega-category]');
      var contents = item.querySelectorAll('[data-mega-content]');
      if (categories.length === 0 || contents.length === 0) return;

      categories.forEach(function(cat) {
        cat.addEventListener('mouseenter', function() {
          categories.forEach(function(c) { c.classList.remove('mega-nav__category--active'); });
          contents.forEach(function(c) { c.classList.remove('mega-nav__subcontent--active'); });
          cat.classList.add('mega-nav__category--active');

          var link = cat.querySelector('.mega-nav__category-link span');
          if (!link) return;
          var handle = link.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          var target = item.querySelector('[data-mega-content="' + handle + '"]');
          if (target) target.classList.add('mega-nav__subcontent--active');
        });
      });
    });

    /* Mobile drawer */
    var drawer = document.getElementById('mobile-drawer');
    var toggleBtn = document.querySelector('[data-drawer-toggle]');

    if (drawer) {
      var mobileDrawer = initDrawer(drawer, 'mobile-drawer--open', '[data-drawer-close]',
        function() { if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true'); },
        function() { if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false'); }
      );

      if (toggleBtn) toggleBtn.addEventListener('click', mobileDrawer.open);

      drawer.querySelectorAll('[data-mobile-expand]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var expanded = this.getAttribute('aria-expanded') === 'true';
          var sub = this.closest('.mobile-nav__item').querySelector(':scope > .mobile-nav__sub');
          if (!sub) return;
          this.setAttribute('aria-expanded', !expanded);
          sub.hidden = expanded;
        });
      });
    }

    /* Cart drawer */
    var cartDrawer = document.getElementById('cart-drawer');
    var cartToggle = document.querySelector('[data-cart-toggle]');

    if (cartDrawer && cartToggle) {
      var sectionId = attr('section-id');

      function availableMsg(qty) {
        if (strings.onlyXAvailable) return strings.onlyXAvailable.replace(new RegExp('[{][{]\\s*count\\s*[}][}]'), qty);
        return 'Only ' + qty + ' available';
      }

      function showDrawerWarning(itemEl, msg) {
        var existing = itemEl.querySelector('.cart-drawer__item-warning');
        if (existing) existing.remove();
        var warning = document.createElement('p');
        warning.className = 'cart-drawer__item-warning';
        warning.textContent = msg;
        itemEl.querySelector('.cart-drawer__item-info').appendChild(warning);
        setTimeout(function() { warning.remove(); }, 3000);
      }

      function updateHeaderCount(count) {
        var headerCount = document.querySelector('.header__cart-count');
        if (headerCount) {
          if (count > 0) { headerCount.textContent = count; }
          else { headerCount.remove(); }
        } else if (count > 0) {
          var cartBtn = document.querySelector('[data-cart-toggle]');
          if (cartBtn) {
            var span = document.createElement('span');
            span.className = 'header__cart-count';
            span.textContent = count;
            cartBtn.appendChild(span);
          }
        }
      }

      function updateDrawerMeta(cart) {
        var subtotalEl = cartDrawer.querySelector('[data-cart-drawer-subtotal]');
        if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price);
        var countEl = cartDrawer.querySelector('[data-cart-drawer-count]');
        if (countEl) countEl.textContent = cart.item_count;
        updateHeaderCount(cart.item_count);
        var emptyEl = cartDrawer.querySelector('[data-cart-drawer-empty]');
        var footerEl = cartDrawer.querySelector('[data-cart-drawer-footer]');
        if (emptyEl) emptyEl.hidden = cart.item_count > 0;
        if (footerEl) footerEl.hidden = cart.item_count === 0;
      }

      function changeCartItem(key, quantity) {
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: key, quantity: quantity })
        })
        .then(function(r) { return r.json(); });
      }

      function bindCartItems() {
        cartDrawer.querySelectorAll('[data-cart-drawer-item]').forEach(function(item) {
          var key = item.getAttribute('data-line-key');
          var qtyValue = item.querySelector('[data-drawer-qty-value]');
          var minusBtn = item.querySelector('[data-drawer-qty-minus]');
          var plusBtn = item.querySelector('[data-drawer-qty-plus]');
          var removeBtn = item.querySelector('[data-drawer-remove]');
          var maxQty = parseInt(item.getAttribute('data-inventory-quantity'), 10);
          var policy = item.getAttribute('data-inventory-policy');
          var hasLimit = policy === 'deny' && !isNaN(maxQty);

          function checkPlusBtn(currentQty) {
            if (!plusBtn) return;
            plusBtn.disabled = hasLimit && currentQty >= maxQty;
          }

          checkPlusBtn(parseInt(qtyValue.textContent, 10) || 1);

          function updateQty(newQty) {
            if (newQty < 0) newQty = 0;

            if (hasLimit && newQty > maxQty) {
              showDrawerWarning(item, availableMsg(maxQty));
              checkPlusBtn(maxQty);
              return;
            }

            if (qtyValue) qtyValue.textContent = newQty;
            if (newQty === 0) item.style.opacity = '0.5';

            changeCartItem(key, newQty).then(function(cart) {
              updateDrawerMeta(cart);

              if (newQty === 0) { item.remove(); return; }

              var lineItem = cart.items.find(function(i) { return i.key === key; });
              if (lineItem && lineItem.quantity < newQty) {
                hasLimit = true;
                maxQty = lineItem.quantity;
                qtyValue.textContent = lineItem.quantity;
                showDrawerWarning(item, availableMsg(lineItem.quantity));
                checkPlusBtn(lineItem.quantity);
              } else {
                checkPlusBtn(newQty);
              }

              var lineTotalEl = item.querySelector('[data-drawer-line-total]');
              if (lineTotalEl && lineItem) lineTotalEl.textContent = formatMoney(lineItem.line_price);

              var unitPriceEl = item.querySelector('.cart-drawer__item-unit-price');
              if (lineItem && lineItem.quantity > 1) {
                var unitText = formatMoney(lineItem.price) + ' ' + (strings.each || 'each');
                if (unitPriceEl) { unitPriceEl.textContent = unitText; }
                else {
                  var priceRow = item.querySelector('.cart-drawer__item-price-row');
                  if (priceRow) {
                    var u = document.createElement('span');
                    u.className = 'cart-drawer__item-unit-price';
                    u.textContent = unitText;
                    priceRow.appendChild(u);
                  }
                }
              } else if (unitPriceEl) {
                unitPriceEl.remove();
              }
            });
          }

          if (minusBtn) minusBtn.addEventListener('click', function() {
            updateQty((parseInt(qtyValue.textContent, 10) || 1) - 1);
          });
          if (plusBtn) plusBtn.addEventListener('click', function() {
            updateQty((parseInt(qtyValue.textContent, 10) || 1) + 1);
          });
          if (removeBtn) removeBtn.addEventListener('click', function() { updateQty(0); });
        });
      }

      function refreshDrawer() {
        return fetch('/?section_id=' + sectionId)
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var temp = document.createElement('div');
            temp.innerHTML = html;

            var freshItems = temp.querySelector('[data-cart-drawer-items]');
            var currentItems = cartDrawer.querySelector('[data-cart-drawer-items]');
            if (freshItems && currentItems) currentItems.innerHTML = freshItems.innerHTML;

            var freshCount = temp.querySelector('[data-cart-drawer-count]');
            var currentCount = cartDrawer.querySelector('[data-cart-drawer-count]');
            if (freshCount && currentCount) currentCount.textContent = freshCount.textContent;

            var freshSubtotal = temp.querySelector('[data-cart-drawer-subtotal]');
            var currentSubtotal = cartDrawer.querySelector('[data-cart-drawer-subtotal]');
            if (freshSubtotal && currentSubtotal) currentSubtotal.textContent = freshSubtotal.textContent;

            var freshEmpty = temp.querySelector('[data-cart-drawer-empty]');
            var currentEmpty = cartDrawer.querySelector('[data-cart-drawer-empty]');
            if (freshEmpty && currentEmpty) currentEmpty.hidden = freshEmpty.hidden;

            var freshFooter = temp.querySelector('[data-cart-drawer-footer]');
            var currentFooter = cartDrawer.querySelector('[data-cart-drawer-footer]');
            if (freshFooter && currentFooter) currentFooter.hidden = freshFooter.hidden;

            var freshHeaderCount = temp.querySelector('.header__cart-count');
            if (freshHeaderCount) {
              updateHeaderCount(parseInt(freshHeaderCount.textContent, 10) || 0);
            }

            bindCartItems();
          });
      }

      function refreshAndOpenDrawer() {
        refreshDrawer().then(function() { cartDrawerCtrl.open(); });
      }

      var cartDrawerCtrl = initDrawer(cartDrawer, 'cart-drawer--open', '[data-cart-drawer-close]');
      cartToggle.addEventListener('click', refreshAndOpenDrawer);
      bindCartItems();
      window.openCartDrawer = refreshAndOpenDrawer;
    }

    /* Instant search */
    var searchContainer = document.querySelector('[data-instant-search]');
    if (searchContainer) {
      var input = searchContainer.querySelector('[data-instant-search-input]');
      var resultsEl = searchContainer.querySelector('[data-instant-search-results]');
      var body = searchContainer.querySelector('[data-instant-search-body]');
      var viewAll = searchContainer.querySelector('[data-instant-search-view-all]');
      var searchType = searchContainer.querySelector('input[name="type"]');
      var typeParam = searchType ? searchType.value : 'product';
      var debounceTimer = null;
      var activeIndex = -1;

      function showResults() { resultsEl.hidden = false; }
      function hideResults() { resultsEl.hidden = true; activeIndex = -1; }

      function createSearchItem(entry) {
        var r = entry.item;
        var link = document.createElement('a');
        link.href = r.url;
        link.className = 'instant-search__item';

        var imgWrap = document.createElement('div');
        imgWrap.className = 'instant-search__item-image';
        var imgSrc = (r.featured_image && r.featured_image.url) || r.image || '';
        if (imgSrc) {
          var img = document.createElement('img');
          img.src = imgSrc;
          img.alt = '';
          img.loading = 'lazy';
          imgWrap.appendChild(img);
        }
        link.appendChild(imgWrap);

        var info = document.createElement('div');
        info.className = 'instant-search__item-info';
        var title = document.createElement('div');
        title.className = 'instant-search__item-title';
        title.textContent = r.title;
        info.appendChild(title);

        var meta = '';
        if (entry.type === 'product' && r.vendor) meta = r.vendor;
        else if (entry.type === 'article') meta = strings.typeArticle || 'Article';
        else if (entry.type === 'page') meta = strings.typePage || 'Page';

        if (meta) {
          var metaEl = document.createElement('div');
          metaEl.className = 'instant-search__item-meta';
          metaEl.textContent = meta;
          info.appendChild(metaEl);
        }
        link.appendChild(info);

        var priceStr = r.price_min || r.price || '';
        if (entry.type === 'product' && priceStr) {
          var priceEl = document.createElement('span');
          priceEl.className = 'instant-search__item-price';
          priceEl.textContent = formatMoney(Math.round(parseFloat(priceStr) * 100));
          link.appendChild(priceEl);
        }

        return link;
      }

      function renderResults(data) {
        var res = data.resources && data.resources.results ? data.resources.results : {};
        var all = [].concat(
          (res.products || []).map(function(p) { return { type: 'product', item: p }; }),
          (res.articles || []).map(function(a) { return { type: 'article', item: a }; }),
          (res.pages || []).map(function(p) { return { type: 'page', item: p }; })
        );

        body.textContent = '';

        if (all.length === 0) {
          var empty = document.createElement('div');
          empty.className = 'instant-search__empty';
          empty.textContent = strings.noResults || 'No results found';
          body.appendChild(empty);
          viewAll.hidden = true;
          showResults();
          return;
        }

        all.forEach(function(entry) { body.appendChild(createSearchItem(entry)); });
        viewAll.hidden = false;
        viewAll.href = '/search?q=' + encodeURIComponent(input.value) + '&type=' + typeParam;
        showResults();
        activeIndex = -1;
      }

      function doSearch(query) {
        if (!query || query.length < 2) { hideResults(); return; }

        body.textContent = '';
        var loading = document.createElement('div');
        loading.className = 'instant-search__loading';
        loading.textContent = strings.searching || 'Searching...';
        body.appendChild(loading);
        viewAll.hidden = true;
        showResults();

        fetch('/search/suggest.json?q=' + encodeURIComponent(query) + '&resources[type]=' + typeParam + '&resources[limit]=6')
          .then(function(r) {
            if (!r.ok) throw new Error(r.status);
            return r.json();
          })
          .then(renderResults)
          .catch(function() {
            body.textContent = '';
            var err = document.createElement('div');
            err.className = 'instant-search__empty';
            err.textContent = strings.searchError || 'Something went wrong';
            body.appendChild(err);
            viewAll.hidden = true;
          });
      }

      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = this.value.trim();
        debounceTimer = setTimeout(function() { doSearch(q); }, 250);
      });

      input.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && body.children.length) showResults();
      });

      input.addEventListener('keydown', function(e) {
        var items = body.querySelectorAll('.instant-search__item');
        if (!items.length || resultsEl.hidden) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, items.length - 1);
          items.forEach(function(el, i) { el.classList.toggle('instant-search__item--active', i === activeIndex); });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
          items.forEach(function(el, i) { el.classList.toggle('instant-search__item--active', i === activeIndex); });
        } else if (e.key === 'Enter' && activeIndex >= 0) {
          e.preventDefault();
          items[activeIndex].click();
        } else if (e.key === 'Escape') {
          hideResults();
          input.blur();
        }
      });

      document.addEventListener('click', function(e) {
        if (!searchContainer.contains(e.target)) hideResults();
      });
    }
  })();
{% endjavascript %}

