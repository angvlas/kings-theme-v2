{% liquid
  assign has_file = false
  if section.settings.file != blank
    assign has_file = true
  endif
  assign has_link = false
  if section.settings.link != blank
    assign has_link = true
  endif
%}

<div class="cta-banner">
  <div class="cta-banner__text">
    {% if section.settings.heading != blank %}
      <h2 class="cta-banner__title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="cta-banner__desc">{{ section.settings.description }}</p>
    {% endif %}
  </div>
  {% if has_file or has_link %}
    {% if has_file %}
      {% assign cta_url = section.settings.file %}
    {% else %}
      {% assign cta_url = section.settings.link %}
    {% endif %}
    <a
      class="cta-banner__button"
      href="{{ cta_url }}"
      {% if has_file %}
        download
      {% endif %}
    >
      {{ section.settings.button_label }}
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  {% endif %}
</div>

{% stylesheet %}
  .cta-banner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    background-color: #000;
    color: #fff;
    padding: 28px 24px;
    border-radius: 12px;
  }

  @media (min-width: 750px) {
    .cta-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 32px 40px;
    }
  }

  .cta-banner__text {
    flex: 1;
    min-width: 0;
  }

  .cta-banner__title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  @media (min-width: 750px) {
    .cta-banner__title {
      font-size: 1.5rem;
    }
  }

  .cta-banner__desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
  }

  .cta-banner__button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 12px 24px;
    background-color: #f4b400;
    color: #1a1a1a;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 999px;
    transition: opacity 0.15s ease;
  }

  .cta-banner__button:hover {
    opacity: 0.9;
  }

  @media (min-width: 750px) {
    .cta-banner__button {
      align-self: auto;
      flex-shrink: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cta_banner.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Start now!"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Download"
    },
    {
      "type": "header",
      "content": "t:labels.cta_destination"
    },
    {
      "type": "file_reference",
      "id": "file",
      "label": "t:labels.cta_file",
      "info": "t:labels.cta_file_info"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:labels.cta_link",
      "info": "t:labels.cta_link_info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.cta_banner.name"
    }
  ]
}
{% endschema %}
