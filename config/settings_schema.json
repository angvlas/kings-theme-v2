[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "1200px",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "1400px",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "1200px"
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "body_background_color",
        "default": "#f7f7f8",
        "label": "t:labels.body_background"
      },
      {
        "type": "color",
        "id": "card_background_color",
        "default": "#ffffff",
        "label": "t:labels.card_background"
      },
      {
        "type": "color",
        "id": "header_color",
        "default": "#333333",
        "label": "t:labels.header_color"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "t:general.branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon"
      }
    ]
  },
  {
    "name": "t:general.slideshow",
    "settings": [
      {
        "type": "range",
        "id": "slide_speed",
        "label": "t:labels.slide_speed",
        "info": "t:labels.slide_speed_info",
        "min": 2,
        "max": 10,
        "step": 1,
        "unit": "s",
        "default": 5
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "textarea",
        "id": "cart_notice_1",
        "label": "t:labels.cart_notice_1"
      },
      {
        "type": "textarea",
        "id": "cart_notice_2",
        "label": "t:labels.cart_notice_2"
      },
      {
        "type": "textarea",
        "id": "cart_notice_3",
        "label": "t:labels.cart_notice_3"
      }
    ]
  },
  {
    "name": "t:general.social_media",
    "settings": [
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_twitter",
        "label": "X / Twitter"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_pinterest",
        "label": "Pinterest"
      }
    ]
  },
  {
    "name": "t:general.images",
    "settings": [
      {
        "type": "image_picker",
        "id": "placeholder_image",
        "label": "t:labels.placeholder_image"
      }
    ]
  },
  {
    "name": "t:general.inventory",
    "settings": [
      {
        "type": "header",
        "content": "t:general.low_stock"
      },
      {
        "type": "checkbox",
        "id": "low_stock_enabled",
        "label": "t:labels.low_stock_enabled",
        "default": true
      },
      {
        "type": "range",
        "id": "low_stock_threshold",
        "label": "t:labels.low_stock_threshold",
        "info": "t:labels.low_stock_threshold_info",
        "min": 1,
        "max": 20,
        "step": 1,
        "default": 5
      }
    ]
  },
  {
    "name": "t:general.membership",
    "settings": [
      {
        "type": "header",
        "content": "t:general.gold_card"
      },
      {
        "type": "checkbox",
        "id": "show_gold_card_badge",
        "label": "t:labels.show_gold_card_badge",
        "info": "t:labels.show_gold_card_badge_info",
        "default": true
      },
      {
        "type": "text",
        "id": "gold_card_discount_tag",
        "label": "t:labels.gold_card_discount_tag",
        "info": "t:labels.gold_card_discount_tag_info",
        "default": "GOLDCARDDISCOUNT10"
      }
    ]
  },
  {
    "name": "t:general.condition_guide",
    "settings": [
      {
        "type": "text",
        "id": "condition_modal_title",
        "label": "t:labels.condition_modal_title",
        "default": "Condition grading guide"
      },
      {
        "type": "textarea",
        "id": "condition_modal_intro",
        "label": "t:labels.condition_modal_intro",
        "default": "We grade our products using the following industry-standard scale. Each grade reflects the overall condition including cover, spine, and pages."
      },
      { "type": "header", "content": "t:general.condition_grades" },
      {
        "type": "text",
        "id": "condition_grade_1_code",
        "label": "t:labels.condition_grade_code",
        "default": "NM"
      },
      {
        "type": "text",
        "id": "condition_grade_1_name",
        "label": "t:labels.condition_grade_name",
        "default": "Near mint"
      },
      {
        "type": "textarea",
        "id": "condition_grade_1_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "Nearly perfect. Minor imperfections such as a tiny spine stress or very light corner wear. Cover is flat with high gloss. Pages are off-white to white."
      },
      {
        "type": "text",
        "id": "condition_grade_2_code",
        "label": "t:labels.condition_grade_code",
        "default": "VF"
      },
      {
        "type": "text",
        "id": "condition_grade_2_name",
        "label": "t:labels.condition_grade_name",
        "default": "Very fine"
      },
      {
        "type": "textarea",
        "id": "condition_grade_2_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "An above-average copy with minor wear. Small creases, light spine stress, or minor corner blunting may be present. Cover retains most of its gloss."
      },
      {
        "type": "text",
        "id": "condition_grade_3_code",
        "label": "t:labels.condition_grade_code",
        "default": "FN"
      },
      {
        "type": "text",
        "id": "condition_grade_3_name",
        "label": "t:labels.condition_grade_name",
        "default": "Fine"
      },
      {
        "type": "textarea",
        "id": "condition_grade_3_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "An average, readable copy with moderate wear. Creases, minor spine roll, and some loss of gloss may be present. Pages may be slightly tanned."
      },
      {
        "type": "text",
        "id": "condition_grade_4_code",
        "label": "t:labels.condition_grade_code",
        "default": "VG"
      },
      {
        "type": "text",
        "id": "condition_grade_4_name",
        "label": "t:labels.condition_grade_name",
        "default": "Very good"
      },
      {
        "type": "textarea",
        "id": "condition_grade_4_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "A below-average copy showing significant wear. Noticeable creasing, spine wear, and corner wear. Cover may have small tears or chips. Pages are tanned."
      },
      {
        "type": "text",
        "id": "condition_grade_5_code",
        "label": "t:labels.condition_grade_code",
        "default": "GD"
      },
      {
        "type": "text",
        "id": "condition_grade_5_name",
        "label": "t:labels.condition_grade_name",
        "default": "Good"
      },
      {
        "type": "textarea",
        "id": "condition_grade_5_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "A well-read copy with heavy wear. Significant creasing, rolling, and possible small pieces missing from the cover. Cover may be loose. Pages are browned."
      },
      {
        "type": "text",
        "id": "condition_grade_6_code",
        "label": "t:labels.condition_grade_code",
        "default": "FR"
      },
      {
        "type": "text",
        "id": "condition_grade_6_name",
        "label": "t:labels.condition_grade_name",
        "default": "Fair"
      },
      {
        "type": "textarea",
        "id": "condition_grade_6_desc",
        "label": "t:labels.condition_grade_desc",
        "default": "A heavily worn copy. Large tears, chunks missing, heavy creasing, soiling, or water damage. Covers may be detached. Suitable for reading copies only."
      }
    ]
  }
]
